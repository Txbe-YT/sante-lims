<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.AuditTrailController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1B3A6B; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #4a6fa5;"/>
            <Label text="Audit Trail"
                   style="-fx-text-fill: #a0b4cc; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Dashboard" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #a0b4cc;
                           -fx-border-color: #4a6fa5; -fx-border-radius: 4;
                           -fx-background-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="System Audit Log"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B3A6B;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Search by action:"
                       style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="searchField" promptText="e.g. LOGIN, CREATED..."
                           prefWidth="200"
                           style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                <Button text="Search" onAction="#handleSearch"
                        style="-fx-background-color: #1B3A6B; -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Button text="Show All" onAction="#handleShowAll"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>

            <Label text="This log is read-only and cannot be modified or deleted."
                   style="-fx-text-fill: #C9A84C; -fx-font-size: 12px; -fx-font-style: italic;"/>

            <TableView fx:id="auditTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="idColumn" text="#" prefWidth="60"/>
                    <TableColumn fx:id="userColumn" text="User" prefWidth="160"/>
                    <TableColumn fx:id="actionColumn" text="Action" prefWidth="180"/>
                    <TableColumn fx:id="tableColumn" text="Target Table" prefWidth="130"/>
                    <TableColumn fx:id="detailsColumn" text="Details" prefWidth="300"/>
                    <TableColumn fx:id="timeColumn" text="Timestamp" prefWidth="160"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>