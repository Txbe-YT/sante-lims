<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.santediagnostics.controllers.VerificationController" prefWidth="800" prefHeight="600" style="-fx-background-color: #f0f4f8;">
    <center>
        <VBox alignment="CENTER" spacing="20" maxWidth="500" maxHeight="400" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <Label text="Verify Your Account" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1B3A6B;"/>
            <Label text="We sent a verification token to your email. Please paste it below to activate your account." wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #4a5568;"/>
            
            <TextField fx:id="tokenField" promptText="Paste your token here..." prefHeight="40" style="-fx-font-size: 14px;"/>
            
            <Button text="Verify &amp; Activate" onAction="#handleVerify" prefWidth="Infinity" prefHeight="40" style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;"/>
            
            <Label fx:id="statusLabel" text=""/>
            <Label fx:id="messageLabel" wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #4a5568;"/>
            
            <Button text="← Back to Login" onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: #718096; -fx-cursor: hand; -fx-underline: true;"/>
        </VBox>
    </center>
</BorderPane>