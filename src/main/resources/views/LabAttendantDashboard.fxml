<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.LabAttendantDashboardController"
            style="-fx-background-color: #f0f4f8;">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15 30;">
            <Label text="Sante Diagnostics LIMS" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="|" style="-fx-text-fill: #7f8c8d; -fx-font-size: 18px;"/>
            <Label text="Lab Portal" style="-fx-text-fill: #bdc3c7; -fx-font-size: 16px;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="welcomeLabel" text="Welcome, Attendant" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="Logout" onAction="#handleLogout" 
                    style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 4; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="40">
            <padding>
                <Insets top="40" right="50" bottom="40" left="50"/>
            </padding>
            
            <VBox alignment="CENTER" spacing="10">
                <Label text="Lab Attendant Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f766e;"/>
                <Label text="Monitor daily lab metrics and manage operations" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
            </VBox>

            <HBox spacing="24" alignment="CENTER">
                <VBox alignment="CENTER" minWidth="220" spacing="10" 
                      style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <Label text="Pending Collections" style="-fx-text-fill: #718096; -fx-font-size: 15px;"/>
                    <Label fx:id="pendingCollectionsLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e53e3e;"/>
                </VBox>
                
                <VBox alignment="CENTER" minWidth="220" spacing="10" 
                      style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <Label text="Samples Processing" style="-fx-text-fill: #718096; -fx-font-size: 15px;"/>
                    <Label fx:id="processingLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3182ce;"/>
                </VBox>
                
                <VBox alignment="CENTER" minWidth="220" spacing="10" 
                      style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <Label text="Awaiting Verification" style="-fx-text-fill: #718096; -fx-font-size: 15px;"/>
                    <Label fx:id="awaitingVerificationLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #805ad5;"/>
                </VBox>
            </HBox>

            <Separator maxWidth="800"/>

            <Label text="Quick Actions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            
            <FlowPane alignment="CENTER" hgap="20" vgap="20" maxWidth="800">
                <Button text="👤 Create Patient Account" onAction="#goToCreatePatient" prefWidth="250" prefHeight="50"
                        style="-fx-background-color: white; -fx-text-fill: #0f766e; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #0f766e; -fx-border-radius: 5; -fx-cursor: hand;"/>
                
                <Button text="🧪 Sample Lifecycle Tracking" onAction="#goToSampleTracking" prefWidth="250" prefHeight="50"
                        style="-fx-background-color: white; -fx-text-fill: #0f766e; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #0f766e; -fx-border-radius: 5; -fx-cursor: hand;"/>
                
                <Button text="📄 Result Upload &amp; Validation" onAction="#goToResults" prefWidth="250" prefHeight="50"
                        style="-fx-background-color: white; -fx-text-fill: #0f766e; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #0f766e; -fx-border-radius: 5; -fx-cursor: hand;"/>
                
                <Button text="💳 Lab Payment Queue" onAction="#goToPaymentQueue" prefWidth="250" prefHeight="50"
                        style="-fx-background-color: white; -fx-text-fill: #0f766e; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #0f766e; -fx-border-radius: 5; -fx-cursor: hand;"/>
            </FlowPane>
            
        </VBox>
    </center>
</BorderPane>