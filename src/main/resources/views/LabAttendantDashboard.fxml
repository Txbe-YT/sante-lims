<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.LabAttendantDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #0F7173; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #0a4f51;"/>
            <Label text="Lab Attendant"
                   style="-fx-text-fill: #b2dfdf; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: #b2dfdf; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #b2dfdf;
                           -fx-border-color: #0a4f51; -fx-border-radius: 4;
                           -fx-background-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="32" style="-fx-padding: 40;">
            <Label text="Lab Attendant Dashboard"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0F7173;"/>

            <HBox spacing="24" alignment="CENTER">
                <VBox alignment="CENTER" minWidth="180" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <Label text="Pending Collections" style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
                    <Label text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0F7173;"/>
                </VBox>
                <VBox alignment="CENTER" minWidth="180" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <Label text="Awaiting Verification" style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
                    <Label text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e53e3e;"/>
                </VBox>
            </HBox>

            <HBox spacing="16" alignment="CENTER">
                <Button text="Create Patient Account" onAction="#goToCreatePatient"
                        style="-fx-background-color: #0F7173; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Sample Lifecycle" onAction="#goToSampleTracking"
                        style="-fx-background-color: #1B3A6B; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Result Validation" onAction="#goToResults"
                        style="-fx-background-color: #C9A84C; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Payment Queue" onAction="#goToPaymentQueue"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>