<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.santediagnostics.controllers.TestCatalogController" 
            prefWidth="1200" prefHeight="750" 
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0F7173; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #0a4f51;"/>
            <Label text="Order New Test" style="-fx-text-fill: #b2dfdf; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Dashboard" onAction="#goToDashboard" 
                    style="-fx-background-color: transparent; -fx-text-fill: #b2dfdf; -fx-border-color: #0a4f51; -fx-border-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 40;">
            <Label text="Available Laboratory Tests" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0F7173;"/>
            <Label text="Select a test from the catalog below to place an order." style="-fx-text-fill: #5a6e7c;"/>
            
            <Label fx:id="statusLabel" text="" style="-fx-font-size: 14px;"/>
            
            <TableView fx:id="testCatalogTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6,0,0,1);">
                <columns>
                    <TableColumn text="Test Name" prefWidth="300" style="-fx-font-weight: bold; -fx-text-fill: #0F7173;">
                        <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Category" prefWidth="200">
                        <cellValueFactory><PropertyValueFactory property="category"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Price (₦)" prefWidth="150" style="-fx-font-weight: bold;">
                        <cellValueFactory><PropertyValueFactory property="price"/></cellValueFactory>
                    </TableColumn>
                </columns>
                <placeholder>
                    <Label text="Loading available tests..." style="-fx-text-fill: #a0aec0; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Order Selected Test" onAction="#handleOrderTest" 
                        style="-fx-background-color: #0F7173; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>