<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.SampleLifecycleController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #0F7173; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #0a4f51;"/>
            <Label text="Sample Lifecycle Tracker"
                   style="-fx-text-fill: #b2dfdf; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Lab Dashboard" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #b2dfdf;
                           -fx-border-color: #0a4f51; -fx-border-radius: 4;
                           -fx-background-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Active Samples"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F7173;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="filterComboBox" onAction="#handleFilter"
                          style="-fx-font-size: 13px;"/>
            </HBox>

            <TableView fx:id="samplesTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="idColumn" text="Sample ID" prefWidth="90"/>
                    <TableColumn fx:id="reqIdColumn" text="Request #" prefWidth="90"/>
                    <TableColumn fx:id="customerColumn" text="Patient Name" prefWidth="200"/>
                    <TableColumn fx:id="testColumn" text="Test Type" prefWidth="200"/>
                    <TableColumn fx:id="statusColumn" text="Current Status" prefWidth="180"/>
                    <TableColumn fx:id="updatedColumn" text="Last Updated" prefWidth="180"/>
                </columns>
            </TableView>

            <HBox spacing="16" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                         -fx-padding: 16 24;">
                <Label text="Update Selected Sample To:" style="-fx-font-size: 14px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                
                <ComboBox fx:id="statusComboBox" prefWidth="220" promptText="Select New Status"
                          style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                 -fx-background-radius: 6; -fx-padding: 4; -fx-font-size: 13px;"/>
                                 
                <Button text="Apply Status Change" onAction="#handleUpdateStatus"
                        style="-fx-background-color: #1B3A6B; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 20; -fx-cursor: hand;"/>
                               
                <Label fx:id="actionLabel" text="" style="-fx-font-size: 13px;"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>