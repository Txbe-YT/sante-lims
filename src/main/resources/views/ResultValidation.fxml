<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.ResultValidationController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0F7173; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #0a4f51;"/>
            <Label text="Result Upload &amp; Validation" style="-fx-text-fill: #b2dfdf; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Lab Dashboard" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #b2dfdf; -fx-border-color: #0a4f51; -fx-border-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 16;">
            <Tab text="1. Upload Results (Samples Processing)">
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: white;">
                    <Label text="Samples Currently Processing" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0F7173;"/>
                    <TableView fx:id="uploadTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 6;">
                        <columns>
                            <TableColumn fx:id="upSampleIdCol" text="Sample ID" prefWidth="90"/>
                            <TableColumn fx:id="upReqIdCol" text="Request #" prefWidth="90"/>
                            <TableColumn fx:id="upPatientCol" text="Patient Name" prefWidth="250"/>
                            <TableColumn fx:id="upTestCol" text="Test Type" prefWidth="250"/>
                        </columns>
                    </TableView>
                    
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #f7fafc; -fx-padding: 16; -fx-border-color: #e2e8f0; -fx-border-radius: 6;">
                        <Button text="1. Select PDF/Image" onAction="#handleSelectFile" style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 16;"/>
                        <Label fx:id="selectedFileLabel" text="No file selected..." style="-fx-text-fill: #718096; -fx-font-style: italic;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="2. Upload &amp; Send for Verification" onAction="#handleUploadSubmit" style="-fx-background-color: #1B3A6B; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20;"/>
                    </HBox>
                    <Label fx:id="uploadStatusLabel" text="" style="-fx-font-size: 13px;"/>
                </VBox>
            </Tab>

            <Tab text="2. Verify Results (Awaiting Validation)">
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: white;">
                    <Label text="Results Awaiting Second-Party Verification" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #C9A84C;"/>
                    <TableView fx:id="verifyTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 6;">
                        <columns>
                            <TableColumn fx:id="verReqIdCol" text="Request #" prefWidth="90"/>
                            <TableColumn fx:id="verPatientCol" text="Patient Name" prefWidth="250"/>
                            <TableColumn fx:id="verTestCol" text="Test Type" prefWidth="250"/>
                            <TableColumn fx:id="verUploaderCol" text="Uploader ID" prefWidth="100"/>
                        </columns>
                    </TableView>
                    
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #f7fafc; -fx-padding: 16; -fx-border-color: #e2e8f0; -fx-border-radius: 6;">
                        <Button text="Preview Attached Document" onAction="#handlePreview" style="-fx-background-color: #4a5568; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 16;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Approve &amp; Verify Result" onAction="#handleVerifySubmit" style="-fx-background-color: #38a169; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20;"/>
                    </HBox>
                    <Label fx:id="verifyStatusLabel" text="" style="-fx-font-size: 13px;"/>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>