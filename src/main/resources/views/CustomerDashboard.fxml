<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.CustomerDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0F7173; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #0a4f51;"/>
            <Label text="Patient Portal" style="-fx-text-fill: #b2dfdf; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #b2dfdf; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #b2dfdf; -fx-border-color: #0a4f51; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
       <VBox spacing="24" style="-fx-padding: 30 40 40 40;">
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 40;">
            <Label text="Patient Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0F7173;"/>
            <Label text="Manage your test requests and track their status" style="-fx-font-size: 14px; -fx-text-fill: #5a6e7c;"/>
        </VBox>
        
        <HBox spacing="20" alignment="CENTER">
              <VBox spacing="8" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2); -fx-padding: 16 24; -fx-min-width: 180;">
                     <Label text="Active Tests" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                     <Label fx:id="activeTestsCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f7173;"/>
              </VBox>

              <VBox spacing="8" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2); -fx-padding: 16 24; -fx-min-width: 180;">
                     <Label text="Pending Payment" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                     <Label fx:id="pendingPaymentCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #E67E22;"/>
              </VBox>

              <VBox spacing="8" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2); -fx-padding: 16 24; -fx-min-width: 180;">
                     <Label text="Completed Tests" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                     <Label fx:id="completedTestsCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27AE60;"/>
              </VBox>
        </HBox>

        <Label text="Test Requests" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill:#2d3748; -fx-padding: 0 0 8 0;"/>

        <TableView fx:id="testRequestsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius:12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6,0,0,1);">
              <columns>
                     <TableColumn text="Request ID" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #0F7173;">
                            <cellValueFactory>
                                   <PropertyValueFactory property="id"/>
                            </cellValueFactory>
                     </TableColumn>

                     <TableColumn text="Test Name" prefWidth="180">
                            <cellValueFactory>
                                   <PropertyValueFactory property="testTypeName"/>
                            </cellValueFactory>
                     </TableColumn>

                     <TableColumn text="Requested Date" prefWidth="120">
                            <cellValueFactory>
                                   <PropertyValueFactory property="orderedAt"/>
                            </cellValueFactory>
                     </TableColumn>

                     <TableColumn text="Sample Status" prefWidth="130" style="-fx-font-weight: bold;">
                            <cellValueFactory>
                                   <PropertyValueFactory property="status"/>
                            </cellValueFactory>
                     </TableColumn>

                     <TableColumn text="Payment Status" prefWidth="120">
                            <cellValueFactory>
                                   <PropertyValueFactory property="paymentStatus"/>
                            </cellValueFactory>
                     </TableColumn>

                     <TableColumn text="Expected Completion" prefWidth="140">
                            <cellValueFactory>
                                   <PropertyValueFactory property="formattedExpectedCompletion"/>
                            </cellValueFactory>
                     </TableColumn>

                     <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100" />
               </columns>

              <placeholder>
                     <Label text="No test requests found" style="-fx-text-fill: #a0aec0; -fx-font-size: 14px;" />
              </placeholder>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15">
                <Button text="+ New Test Request" onAction="#handleNewTestRequest" style="-fx-background-color: #0F7173; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 24; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(15,113,115,0.3), 8, 0, 0, 2);"/>
                <Button text="View History" onAction="#handleViewHistory" style="-fx-background-color: transparent; -fx-text-fill: #0F7173; -fx-font-weight: bold; -fx-border-color: #0F7173; -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 8 22; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
              <Label text="Filter by:" style="-fx-text-fill: #4a5568; -fx-font-size:13px;"/>
              
              <ComboBox fx:id="statusFilter" promptText="All Status" prefWidth="130" style="-fx-background-color: white; -fx-background-radius: 20;"/>
              <ComboBox fx:id="paymentFilter" promptText="All Payment" prefWidth="130" style="-fx-background-color: white; -fx-background-radius: 20;"/>
              
              <Region HBox.hgrow="ALWAYS"/>
              <TextField fx:id="searchField" promptText="Search by test name or ID..." prefWidth="200" style="-fx-background-color: white; -fx-background-radius:20; -fx-padding: 6 12; -fx-border-color:e2e8f0; -fx-border-radius: 20;"/>
              <Button text="Search" onAction="#handleSearch" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"/>
        </HBox>
       </VBox>
    </center>

</BorderPane>