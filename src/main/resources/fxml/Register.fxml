<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.RegisterController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <center>
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);"
              maxWidth="420">

            <!-- Header -->
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: #0F7173; -fx-background-radius: 12 12 0 0;
                         -fx-padding: 30 40 24 40;">
                <Label text="Create Patient Account"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Register to access your test results online."
                       style="-fx-text-fill: #b2dfdf; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="16" style="-fx-padding: 36 40 36 40;">

                <VBox spacing="6">
                    <Label text="Full Name" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="fullNameField" promptText="Enter your full name"
                               style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Email Address" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="emailField" promptText="Enter your email"
                               style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="passwordField" promptText="Create a password"
                                   style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirm Password" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"
                                   style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;" wrapText="true"/>
                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #38a169; -fx-font-size: 12px;" wrapText="true"/>

                <Button text="Create Account" onAction="#handleRegister"
                        maxWidth="Infinity"
                        style="-fx-background-color: #0F7173; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-padding: 12; -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Already have an account?"
                           style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                    <Hyperlink text="Sign in" onAction="#goToLogin"
                               style="-fx-font-size: 12px; -fx-text-fill: #0F7173;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>