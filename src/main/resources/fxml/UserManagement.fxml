<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.UserManagementController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1B3A6B; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #4a6fa5;"/>
            <Label text="User Management"
                   style="-fx-text-fill: #a0b4cc; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Dashboard" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #a0b4cc;
                           -fx-border-color: #4a6fa5; -fx-border-radius: 4;
                           -fx-background-radius: 4; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="24" style="-fx-padding: 24;">

            <!-- Left: Create User Form -->
            <VBox spacing="16" minWidth="340"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Create New Account"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1B3A6B;"/>

                <VBox spacing="6">
                    <Label text="Full Name" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="fullNameField" promptText="Enter full name"
                               style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Email Address" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="emailField" promptText="Enter email address"
                               style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Temporary Password" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="passwordField" promptText="Set temporary password"
                                   style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Role" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <ComboBox fx:id="roleComboBox" maxWidth="Infinity"
                              style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                     -fx-background-radius: 6; -fx-padding: 4; -fx-font-size: 13px;"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;" wrapText="true"/>
                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #38a169; -fx-font-size: 12px;" wrapText="true"/>

                <Button text="Create Account" onAction="#handleCreateUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1B3A6B; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-padding: 12; -fx-cursor: hand;"/>
            </VBox>

            <!-- Right: Users Table -->
            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="All Users"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1B3A6B;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="filterComboBox" onAction="#handleFilter"
                              style="-fx-font-size: 13px;"/>
                </HBox>

                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameColumn" text="Full Name" prefWidth="200"/>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="220"/>
                        <TableColumn fx:id="roleColumn" text="Role" prefWidth="140"/>
                        <TableColumn fx:id="verifiedColumn" text="Verified" prefWidth="80"/>
                        <TableColumn fx:id="createdColumn" text="Created At" prefWidth="160"/>
                    </columns>
                </TableView>

            </VBox>
        </HBox>
    </center>

</BorderPane>