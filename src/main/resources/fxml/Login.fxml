<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.LoginController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <center>
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);"
              maxWidth="420" maxHeight="520">

            <!-- Header Band -->
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: #1B3A6B; -fx-background-radius: 12 12 0 0;
                         -fx-padding: 36 40 30 40;">
                <Label text="Sante Diagnostics"
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="Laboratory Information Management System"
                       style="-fx-text-fill: #a0b4cc; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="16" style="-fx-padding: 36 40 36 40;">

                <Label text="Sign In" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B3A6B;"/>

                <VBox spacing="6">
                    <Label text="Email Address" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="emailField"
                               promptText="Enter your email"
                               style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 10 12;
                                      -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                         -fx-background-radius: 6; -fx-padding: 10 12;
                                         -fx-font-size: 13px;"/>
                </VBox>

                <!-- Error message -->
                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"
                       wrapText="true"/>

                <!-- Login Button -->
                <Button fx:id="loginButton" text="Sign In"
                        maxWidth="Infinity"
                        onAction="#handleLogin"
                        style="-fx-background-color: #1B3A6B; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-padding: 12;
                               -fx-cursor: hand;"/>

                <!-- Register link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="New patient?" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                    <Hyperlink text="Create an account" onAction="#handleRegister"
                               style="-fx-font-size: 12px; -fx-text-fill: #0F7173;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>