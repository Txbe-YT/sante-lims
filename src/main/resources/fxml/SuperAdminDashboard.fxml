<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.SuperAdminDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1B3A6B; -fx-padding: 16 24;">
            <Label text="Sante Diagnostics LIMS"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="|" style="-fx-text-fill: #4a6fa5; -fx-font-size: 18px;"/>
            <Label text="Super Admin"
                   style="-fx-text-fill: #a0b4cc; -fx-font-size: 14px;"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: #a0b4cc; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #a0b4cc;
                           -fx-border-color: #4a6fa5; -fx-border-radius: 4;
                           -fx-background-radius: 4; -fx-padding: 6 14;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 40;">

            <Label text="Super Admin Dashboard"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1B3A6B;"/>
            <Label text="Full dashboard coming soon. Login is working!"
                   style="-fx-font-size: 16px; -fx-text-fill: #718096;"/>

            <!-- Quick action buttons -->
            <HBox spacing="16" alignment="CENTER">
                <Button text="User Management" onAction="#goToUserManagement"
                        style="-fx-background-color: #1B3A6B; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-padding: 12 24;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Test Builder" onAction="#goToTestBuilder"
                        style="-fx-background-color: #0F7173; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-padding: 12 24;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Audit Trail" onAction="#goToAuditTrail"
                        style="-fx-background-color: #C9A84C; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-padding: 12 24;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Test Requests" onAction="#goToTestRequests"
                        style="-fx-background-color: #4a5568; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-padding: 12 24;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>