<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.santediagnostics.controllers.ForcePasswordChangeController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f0f4f8;">

    <center>
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);"
              maxWidth="420">

            <!-- Header Band -->
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: #C9A84C; -fx-background-radius: 12 12 0 0;
                         -fx-padding: 30 40 24 40;">
                <Label text="Password Change Required"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Your account requires a new password before continuing."
                       style="-fx-text-fill: #fff8e7; -fx-font-size: 12px;"
                       wrapText="true"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="16" style="-fx-padding: 36 40 36 40;">

                <VBox spacing="6">
                    <Label text="New Password"
                           style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="newPasswordField"
                                   promptText="Enter new password"
                                   style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                         -fx-background-radius: 6; -fx-padding: 10 12;
                                         -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirm New Password"
                           style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Confirm new password"
                                   style="-fx-border-color: #cbd5e0; -fx-border-radius: 6;
                                         -fx-background-radius: 6; -fx-padding: 10 12;
                                         -fx-font-size: 13px;"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"
                       wrapText="true"/>

                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #38a169; -fx-font-size: 12px;"
                       wrapText="true"/>

                <Button text="Update Password"
                        maxWidth="Infinity"
                        onAction="#handlePasswordChange"
                        style="-fx-background-color: #C9A84C; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-padding: 12;
                               -fx-cursor: hand;"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>